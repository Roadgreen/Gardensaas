generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String
  image          String?
  plan           String    @default("free") // "free" | "pro"
  stripeCustomerId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  gardens        Garden[]
  tasks          Task[]
  accounts       Account[]
  sessions       Session[]
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Garden {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  userId       String        @db.ObjectId
  name         String        @default("My Garden")
  length       Float
  width        Float
  soilType     String
  climateZone  String
  sunExposure  String
  latitude     Float?
  longitude    Float?
  city         String?
  country      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  gardenPlants GardenPlant[]
  seasons      GardenSeason[]
}

model GardenPlant {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  gardenId    String   @db.ObjectId
  plantId     String   // references static plant data from plants.json
  x           Float
  z           Float
  plantedDate DateTime @default(now())
  notes       String?
  garden      Garden   @relation(fields: [gardenId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  title       String
  description String?
  type        String   // "watering" | "weeding" | "harvesting" | "planting" | "maintenance"
  plantId     String?  // optional reference to plant
  dueDate     DateTime
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GardenSeason {
  id        String        @id @default(auto()) @map("_id") @db.ObjectId
  gardenId  String        @db.ObjectId
  garden    Garden        @relation(fields: [gardenId], references: [id], onDelete: Cascade)
  year      Int
  notes     String?
  createdAt DateTime      @default(now())
  plants    SeasonPlant[]
}

model SeasonPlant {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  seasonId      String       @db.ObjectId
  season        GardenSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  plantId       String
  x             Float
  z             Float
  plantedDate   DateTime?
  harvestedDate DateTime?
  yield         Float?       // kg harvested
  notes         String?
  health        String?      // good, average, poor
}

model DailyTip {
  id       String   @id @default(auto()) @map("_id") @db.ObjectId
  text     String
  textFr   String
  plantId  String?  // optional reference to specific plant
  month    Int?     // optional: tip relevant for specific month (1-12)
  category String   // "general" | "watering" | "planting" | "harvest" | "pest"
}
